# Configurações de Produção
# Copie este arquivo para .env.production e configure as variáveis

NODE_ENV=production

# Database - Produção
PROD_DB_HOST=cachorro
# IMPORTANTE: PROD_DB_USER NÃO pode ser "root"! Use outro nome
PROD_DB_USER= 
PROD_DB_PASS=sua-senha-segura
PROD_DB_NAME=cachorro
MYSQL_ROOT_PASSWORD=
PROD_ADMIN_SECRET=

# Porta da aplicação (opcional, padrão é 3000)
PORT=3000

# URL do site para SEO (sitemap, canonical, schema)
# Ex: https://motoinfo.com.br
NEXT_PUBLIC_SITE_URL=


# Configurações de Produção
# Copie este arquivo para .env.production e configure as variáveis

NODE_ENV=production

# Database - Produção
# Se MySQL estiver no Docker Compose, use: mysql (nome do serviço)
# Se MySQL estiver na VPS (fora do Docker), use: localhost ou IP da VPS
PROD_DB_HOST=mysql
PROD_DB_USER=moto_user
PROD_DB_PASS=sua-senha-segura
PROD_DB_NAME=motos

# MySQL Root Password (opcional - se não definido, usa PROD_DB_PASS)
# Se definido, será usado como senha do root do MySQL
MYSQL_ROOT_PASSWORD=

# JWT Secret (deve ser um JSON Web Key)
# Gere um com: node -e "const crypto = require('crypto'); const key = crypto.randomBytes(32).toString('base64'); console.log(JSON.stringify({kty:'oct',k:key,alg:'HS256'}))"
PROD_ADMIN_SECRET={"kty":"oct","k":"SEU_SECRET_KEY_AQUI","alg":"HS256"}

# Porta da aplicação (opcional, padrão é 3000)
PORT=3000

